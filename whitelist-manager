<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Proxy Key Manager</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <style>
        :root {
            --rose-50: #fff1f4;
            --rose-100: #ffe4ea;
            --rose-200: #fecdd7;
            --rose-300: #fda4b4;
            --rose-400: #fb7093;
            --rose-500: #f43f72;
            --rose-600: #e11d5a;
            --pink-soft: #fff0f5;
            --mauve-light: #e8b4ce;
            --cream: #fff8fb;
            --text-dark: #2d1a26;
            --text-mid: #7a4d64;
            --text-light: #b07a96;
            --white: #ffffff;
            --border: #f5c2d7;
            --shadow-sm: 0 2px 8px rgba(244,63,114,0.08);
            --shadow-md: 0 8px 24px rgba(244,63,114,0.12);
            --shadow-lg: 0 20px 60px rgba(200,60,100,0.18);
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family:'DM Sans',sans-serif;
            background: linear-gradient(160deg, #fff0f5 0%, #fce7f0 50%, #ffe4ea 100%);
            min-height:100vh; color:var(--text-dark); line-height:1.5;
        }
        body::before {
            content:''; position:fixed; top:-100px; right:-100px;
            width:400px; height:400px;
            background:radial-gradient(circle, rgba(251,112,147,0.2) 0%, transparent 70%);
            pointer-events:none; z-index:0;
        }
        body::after {
            content:''; position:fixed; bottom:-80px; left:-80px;
            width:320px; height:320px;
            background:radial-gradient(circle, rgba(244,63,114,0.12) 0%, transparent 70%);
            pointer-events:none; z-index:0;
        }
        ::-webkit-scrollbar { width:5px; }
        ::-webkit-scrollbar-track { background:var(--rose-50); }
        ::-webkit-scrollbar-thumb { background:var(--rose-300); border-radius:3px; }

        .screen { display:none; position:relative; z-index:1; }
        .screen.active { display:block; }

        /* LOGIN */
        #loginScreen {
            min-height:100vh; display:none;
            flex-direction:column; align-items:center; justify-content:center; padding:24px;
        }
        #loginScreen.active { display:flex; }

        .login-icon-wrap {
            width:72px; height:72px;
            background:linear-gradient(135deg, var(--rose-400), var(--rose-600));
            border-radius:22px; display:flex; align-items:center; justify-content:center;
            margin-bottom:20px; box-shadow:0 12px 32px rgba(244,63,114,0.4);
            animation:floatIcon 3s ease-in-out infinite; color:white;
        }
        @keyframes floatIcon { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }

        .login-title { font-size:28px; font-weight:700; color:var(--text-dark); margin-bottom:6px; letter-spacing:-0.5px; }
        .login-sub { font-size:14px; color:var(--text-light); margin-bottom:36px; }

        .login-card {
            width:100%; max-width:380px; background:var(--white);
            border:1.5px solid var(--border); border-radius:24px; padding:28px;
            box-shadow:var(--shadow-lg); animation:floatUp 0.5s cubic-bezier(0.22,1,0.36,1);
        }
        @keyframes floatUp {
            from{opacity:0;transform:translateY(20px) scale(0.97)}
            to{opacity:1;transform:translateY(0) scale(1)}
        }

        .field-label {
            font-size:10px; font-weight:700; text-transform:uppercase;
            letter-spacing:1.2px; color:var(--text-light); margin-bottom:8px;
            display:flex; align-items:center; justify-content:space-between;
        }
        .online-dot {
            display:flex; align-items:center; gap:5px;
            font-size:12px; font-weight:600; color:#16a34a; letter-spacing:0; text-transform:none;
        }
        .online-dot::before {
            content:''; width:7px; height:7px; border-radius:50%; background:#22c55e;
            box-shadow:0 0 6px rgba(34,197,94,0.6);
        }

        .key-input-wrap {
            background:var(--pink-soft); border:1.5px solid var(--border); border-radius:14px;
            display:flex; align-items:center; gap:10px; padding:13px 14px; margin-bottom:14px; transition:all 0.2s;
        }
        .key-input-wrap:focus-within {
            border-color:var(--rose-400); background:var(--white); box-shadow:0 0 0 4px rgba(244,63,114,0.1);
        }
        .key-input-icon { color:var(--text-light); flex-shrink:0; display:flex; }
        .key-input-wrap input {
            flex:1; background:transparent; border:none; outline:none;
            font-family:'DM Mono',monospace; font-size:14px; color:var(--text-dark); letter-spacing:2px;
        }
        .key-input-wrap input::placeholder { color:var(--mauve-light); letter-spacing:3px; }
        .key-action-btn {
            background:none; border:none; cursor:pointer; padding:4px;
            color:var(--text-light); transition:color 0.2s; display:flex; align-items:center;
        }
        .key-action-btn:hover { color:var(--rose-500); }

        .btn-verify {
            width:100%; padding:14px;
            background:linear-gradient(135deg, var(--rose-500), var(--rose-600));
            color:white; border:none; border-radius:14px;
            font-size:15px; font-weight:700; font-family:'DM Sans',sans-serif;
            cursor:pointer; transition:all 0.2s; box-shadow:0 6px 20px rgba(244,63,114,0.38);
            display:flex; align-items:center; justify-content:center; gap:8px;
        }
        .btn-verify:hover { transform:translateY(-2px); box-shadow:0 10px 28px rgba(244,63,114,0.45); }
        .btn-verify:disabled { opacity:0.7; cursor:not-allowed; transform:none; }

        .login-footer {
            margin-top:16px; text-align:center; font-size:12px; color:var(--text-light);
            display:flex; align-items:center; justify-content:center; gap:6px;
        }

        .spinner {
            width:16px; height:16px; border:2px solid rgba(255,255,255,0.4);
            border-top-color:white; border-radius:50%; animation:spin 0.7s linear infinite;
        }
        @keyframes spin { to{transform:rotate(360deg)} }

        /* MAIN */
        #mainScreen { min-height:100vh; padding:0 0 48px; }

        .top-bar {
            display:flex; align-items:center; justify-content:space-between;
            padding:18px 20px 0; margin-bottom:22px;
        }
        .top-bar-brand { display:flex; align-items:center; gap:9px; font-size:14px; font-weight:700; color:var(--text-dark); }
        .top-bar-brand-icon {
            width:30px; height:30px;
            background:linear-gradient(135deg, var(--rose-400), var(--rose-600));
            border-radius:9px; display:flex; align-items:center; justify-content:center;
            color:white; box-shadow:0 4px 10px rgba(244,63,114,0.3);
        }
        .btn-signout {
            display:flex; align-items:center; gap:6px; padding:8px 14px;
            background:transparent; border:1.5px solid var(--border); border-radius:10px;
            cursor:pointer; font-size:12px; font-weight:600; color:var(--text-light);
            font-family:'DM Sans',sans-serif; transition:all 0.2s;
        }
        .btn-signout:hover { border-color:var(--rose-400); color:var(--rose-600); background:var(--rose-50); }

        .section-header { padding:0 20px; margin-bottom:6px; }
        .section-title { font-size:24px; font-weight:700; color:var(--text-dark); letter-spacing:-0.4px; }
        .section-sub { font-size:13px; color:var(--text-light); margin-top:3px; }

        .section-eyebrow {
            padding:18px 20px 8px; font-size:10px; font-weight:700;
            text-transform:uppercase; letter-spacing:1.2px; color:var(--text-light);
            display:flex; align-items:center; justify-content:space-between;
        }
        .eyebrow-time { font-size:11px; font-weight:400; text-transform:none; letter-spacing:0; }

        .stat-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; padding:0 20px; margin-bottom:20px; }
        .stat-card {
            background:var(--white); border:1.5px solid var(--border);
            border-radius:18px; padding:18px 16px; box-shadow:var(--shadow-sm); transition:all 0.2s;
        }
        .stat-card:hover { box-shadow:var(--shadow-md); transform:translateY(-2px); }
        .stat-card-label {
            font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px;
            color:var(--text-light); display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;
        }
        .stat-icon { color:var(--text-light); opacity:0.6; display:flex; }
        .stat-card-value { font-size:22px; font-weight:700; color:var(--text-dark); display:flex; align-items:center; gap:6px; }
        .stat-status-dot { width:9px; height:9px; border-radius:50%; background:#22c55e; box-shadow:0 0 8px rgba(34,197,94,0.5); flex-shrink:0; }
        .stat-active { color:#16a34a; }
        .stat-expiry { font-size:18px; color:var(--rose-500); font-weight:700; }
        .stat-progress { margin-top:10px; height:4px; background:var(--rose-100); border-radius:2px; overflow:hidden; }
        .stat-progress-bar { height:100%; background:linear-gradient(90deg, var(--rose-400), var(--rose-600)); border-radius:2px; transition:width 0.5s ease; }
        .stat-sub { font-size:11px; color:var(--text-light); font-weight:400; }

        .reg-card {
            background:var(--white); border:1.5px solid var(--border); border-radius:20px;
            padding:22px 20px; margin:0 20px 20px; box-shadow:var(--shadow-sm);
        }
        .reg-card-title { font-size:17px; font-weight:700; color:var(--text-dark); margin-bottom:4px; }
        .reg-card-sub { font-size:13px; color:var(--text-light); margin-bottom:18px; }

        .ip-detect-box {
            background:var(--pink-soft); border:1.5px solid var(--border); border-radius:14px;
            padding:14px 16px; display:flex; align-items:center; gap:10px; margin-bottom:8px;
        }
        .ip-detect-icon { color:var(--rose-400); display:flex; flex-shrink:0; }
        .ip-detect-value { font-family:'DM Mono',monospace; font-size:14px; color:var(--text-dark); font-weight:500; flex:1; }
        .ip-hint { font-size:12px; color:var(--text-light); display:flex; align-items:flex-start; gap:6px; margin-bottom:16px; }
        .ip-hint-icon { color:var(--text-light); opacity:0.6; flex-shrink:0; display:flex; margin-top:1px; }

        .btn-detect {
            width:100%; padding:13px; background:var(--pink-soft); border:1.5px solid var(--border);
            border-radius:14px; cursor:pointer; font-size:14px; font-weight:600;
            font-family:'DM Sans',sans-serif; color:var(--text-mid); transition:all 0.2s;
            display:flex; align-items:center; justify-content:center; gap:8px; margin-bottom:10px;
        }
        .btn-detect:hover { border-color:var(--rose-300); color:var(--rose-600); background:var(--rose-50); }

        .btn-register {
            width:100%; padding:14px;
            background:linear-gradient(135deg, var(--rose-500), var(--rose-600));
            color:white; border:none; border-radius:14px; font-size:15px; font-weight:700;
            font-family:'DM Sans',sans-serif; cursor:pointer; transition:all 0.2s;
            box-shadow:0 6px 20px rgba(244,63,114,0.35);
            display:flex; align-items:center; justify-content:center; gap:8px;
        }
        .btn-register:hover { transform:translateY(-2px); box-shadow:0 10px 28px rgba(244,63,114,0.45); }
        .btn-register:disabled { opacity:0.65; cursor:not-allowed; transform:none; }

        .ip-list-card {
            background:var(--white); border:1.5px solid var(--border);
            border-radius:20px; margin:0 20px; overflow:hidden; box-shadow:var(--shadow-sm);
        }
        .ip-list-header {
            padding:16px 18px; display:flex; align-items:center; justify-content:space-between;
            border-bottom:1.5px solid var(--border);
        }
        .ip-list-title { font-size:15px; font-weight:700; color:var(--text-dark); display:flex; align-items:center; gap:10px; }
        .ip-count-pill { background:var(--rose-500); color:white; font-size:11px; font-weight:700; border-radius:20px; padding:2px 9px; }
        .btn-refresh { background:none; border:none; cursor:pointer; color:var(--text-light); transition:all 0.3s; padding:4px; display:flex; }
        .btn-refresh:hover { color:var(--rose-500); transform:rotate(90deg); }

        .ip-item { padding:16px 18px; display:flex; align-items:center; gap:14px; border-bottom:1.5px solid var(--border); transition:background 0.2s; }
        .ip-item:last-child { border-bottom:none; }
        .ip-item:hover { background:var(--pink-soft); }
        .ip-item-icon { width:40px; height:40px; background:linear-gradient(135deg, var(--rose-100), var(--rose-200)); border-radius:12px; display:flex; align-items:center; justify-content:center; color:var(--rose-500); flex-shrink:0; }
        .ip-item-info { flex:1; min-width:0; }
        .ip-item-addr { font-family:'DM Mono',monospace; font-size:14px; font-weight:500; color:var(--text-dark); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .ip-item-date { font-size:11px; color:var(--text-light); margin-top:2px; }
        .ip-item-right { display:flex; align-items:center; gap:6px; }
        .status-pill { padding:4px 10px; background:rgba(22,163,74,0.1); color:#16a34a; border-radius:20px; font-size:11px; font-weight:700; display:flex; align-items:center; gap:4px; white-space:nowrap; }
        .status-pill::before { content:''; width:5px; height:5px; border-radius:50%; background:#22c55e; }
        .ip-action-btn { background:none; border:none; cursor:pointer; padding:6px; color:var(--text-light); border-radius:8px; transition:all 0.2s; display:flex; }
        .ip-action-btn:hover { background:var(--rose-50); color:var(--rose-500); }
        .ip-action-btn.del:hover { background:rgba(220,38,38,0.08); color:#dc2626; }

        .empty-state { padding:40px 20px; text-align:center; color:var(--text-light); }
        .empty-icon { display:flex; justify-content:center; margin-bottom:12px; opacity:0.35; }
        .empty-state p { font-size:13px; }

        .toast-wrap { position:fixed; top:20px; left:50%; transform:translateX(-50%); z-index:9999; pointer-events:none; display:flex; flex-direction:column; gap:8px; align-items:center; }
        .toast { padding:11px 18px; border-radius:14px; font-size:13px; font-weight:600; font-family:'DM Sans',sans-serif; display:flex; align-items:center; gap:8px; border:1.5px solid; backdrop-filter:blur(12px); box-shadow:0 8px 24px rgba(0,0,0,0.1); animation:toastIn 0.35s cubic-bezier(0.22,1,0.36,1); white-space:nowrap; }
        @keyframes toastIn { from{opacity:0;transform:translateY(-8px) scale(0.96)} to{opacity:1;transform:translateY(0) scale(1)} }
        .toast.success { background:rgba(240,253,244,0.96); color:#15803d; border-color:#86efac; }
        .toast.error   { background:rgba(254,242,242,0.96); color:#dc2626; border-color:#fca5a5; }
        .toast.info    { background:rgba(255,240,245,0.96); color:var(--rose-600); border-color:var(--rose-200); }

        .hidden { display:none !important; }
    </style>
</head>
<body>

<div class="toast-wrap" id="toastWrap"></div>

<!-- ═══ LOGIN ═══ -->
<div id="loginScreen" class="screen active">
    <div class="login-icon-wrap"><i data-lucide="key-round" width="32" height="32"></i></div>
    <div class="login-title">Proxy Key</div>
    <div class="login-sub">Enter your key to access the panel</div>
    <div class="login-card">
        <div class="field-label">
            YOUR ACCESS KEY
            <span class="online-dot">Online</span>
        </div>
        <div class="key-input-wrap">
            <span class="key-input-icon"><i data-lucide="key" width="16" height="16"></i></span>
            <input type="password" id="keyInput" placeholder="••••••••••••••••••" autocomplete="off">
            <button class="key-action-btn" onclick="toggleKeyVisibility()"><i data-lucide="eye" width="16" height="16" id="eyeIcon"></i></button>
            <button class="key-action-btn" onclick="pasteKey()"><i data-lucide="clipboard" width="16" height="16"></i></button>
        </div>
        <button class="btn-verify" id="verifyBtn" onclick="handleLogin()">
            <span id="verifyText">Verify</span>
            <i data-lucide="arrow-right" width="16" height="16" id="verifyArrow"></i>
            <div class="spinner hidden" id="verifySpinner"></div>
        </button>
        <div class="login-footer">
            <i data-lucide="shield" width="13" height="13"></i>
            Proxy System · Project Private Group
        </div>
    </div>
</div>

<!-- ═══ MAIN ═══ -->
<div id="mainScreen" class="screen">
    <div class="top-bar">
        <div class="top-bar-brand">
            <div class="top-bar-brand-icon"><i data-lucide="shield-check" width="16" height="16"></i></div>
            Whitelist Manager
        </div>
        <button class="btn-signout" onclick="handleLogout()">
            <i data-lucide="log-out" width="13" height="13"></i> Sign out
        </button>
    </div>

    <div class="section-header">
        <div class="section-title">Overview</div>
        <div class="section-sub">Key status and authorized IP management</div>
    </div>

    <div class="section-eyebrow">
        KEY INFORMATION
        <span class="eyebrow-time" id="lastUpdated">Updating…</span>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-card-label">STATUS <span class="stat-icon"><i data-lucide="activity" width="14" height="14"></i></span></div>
            <div class="stat-card-value stat-active"><span class="stat-status-dot"></span>Active</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">EXPIRY <span class="stat-icon"><i data-lucide="timer" width="14" height="14"></i></span></div>
            <div class="stat-expiry" id="expiryDisplay">—</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">ACTIVE IPS <span class="stat-icon"><i data-lucide="wifi" width="14" height="14"></i></span></div>
            <div class="stat-card-value" id="activeIPCount">0 / 1</div>
            <div class="stat-progress"><div class="stat-progress-bar" id="ipProgressBar" style="width:0%"></div></div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">IP LIMIT <span class="stat-icon"><i data-lucide="shield" width="14" height="14"></i></span></div>
            <div class="stat-card-value"><span id="ipLimitVal">1</span> <span class="stat-sub">AUTHORIZED</span></div>
        </div>
    </div>

    <div class="reg-card">
        <div class="reg-card-title">Register New IP</div>
        <div class="reg-card-sub">Authorize an IP to use this key as proxy</div>
        <div class="ip-detect-box">
            <span class="ip-detect-icon"><i data-lucide="globe" width="18" height="18"></i></span>
            <span class="ip-detect-value" id="ipInputDisplay">Detecting your IP…</span>
        </div>
        <div class="ip-hint">
            <span class="ip-hint-icon"><i data-lucide="info" width="13" height="13"></i></span>
            Your IP was filled in automatically. Edit if you want to authorize another.
        </div>
        <button class="btn-detect" onclick="detectIP()">
            <i data-lucide="crosshair" width="16" height="16"></i> Detect my IP
        </button>
        <button class="btn-register" id="registerBtn" onclick="handleRegisterIP()">
            <i data-lucide="plus" width="16" height="16"></i> Register IP
        </button>
    </div>

    <div class="section-eyebrow" style="margin-top:4px;">REGISTERED IPS</div>
    <div class="ip-list-card">
        <div class="ip-list-header">
            <div class="ip-list-title">
                Registered IPs <span class="ip-count-pill" id="ipCountPill">0</span>
            </div>
            <button class="btn-refresh" onclick="loadIPs()"><i data-lucide="refresh-cw" width="16" height="16"></i></button>
        </div>
        <div id="ipListBody">
            <div class="empty-state">
                <div class="empty-icon"><i data-lucide="inbox" width="36" height="36"></i></div>
                <p>No IPs registered yet</p>
            </div>
        </div>
    </div>
</div>

<script>
    // ← เปลี่ยน URL นี้เป็น URL ของคุณ
    const API_BASE = 'https://whitelist-manager-2eod.onrender.com';

    let currentKey = '';
    let detectedIP = '';
    let ipLimit = 1;
    let expiryTimer = null;
    let keyVisible = false;

    // ── LOGIN ──
    async function handleLogin() {
        const key = document.getElementById('keyInput').value.trim();
        if (!key) { showToast('Enter your access key', 'error'); return; }

        const btn = document.getElementById('verifyBtn');
        const txt = document.getElementById('verifyText');
        const arrow = document.getElementById('verifyArrow');
        const spin = document.getElementById('verifySpinner');
        btn.disabled = true; txt.textContent = 'Verifying…';
        arrow.classList.add('hidden'); spin.classList.remove('hidden');

        try {
            const res = await fetch(`${API_BASE}/auth`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ key })
            });
            const data = await res.json();
            if (!data.success) {
                showToast(data.message || 'Invalid key', 'error');
                document.getElementById('keyInput').value = '';
            } else {
                currentKey = key;
                ipLimit = data.ip_limit || 1;
                localStorage.setItem('proxyKey', key);
                startExpiryCountdown(data.expires_at);
                showToast('Access granted.', 'success');
                setTimeout(() => showScreen('mainScreen'), 400);
            }
        } catch {
            showToast('Cannot connect to server', 'error');
        }

        btn.disabled = false; txt.textContent = 'Verify';
        arrow.classList.remove('hidden'); spin.classList.add('hidden');
    }

    function handleLogout() {
        if (!confirm('Sign out?')) return;
        localStorage.removeItem('proxyKey');
        currentKey = '';
        if (expiryTimer) clearInterval(expiryTimer);
        showScreen('loginScreen');
        document.getElementById('keyInput').value = '';
    }

    function toggleKeyVisibility() {
        const inp = document.getElementById('keyInput');
        keyVisible = !keyVisible;
        inp.type = keyVisible ? 'text' : 'password';
        document.getElementById('eyeIcon').setAttribute('data-lucide', keyVisible ? 'eye-off' : 'eye');
        lucide.createIcons();
    }

    async function pasteKey() {
        try {
            const text = await navigator.clipboard.readText();
            document.getElementById('keyInput').value = text;
            showToast('Pasted', 'info');
        } catch { showToast('Cannot access clipboard', 'error'); }
    }

    // ── SCREEN ──
    function showScreen(id) {
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById(id).classList.add('active');
        if (id === 'mainScreen') initDashboard();
    }

    function initDashboard() {
        updateLastUpdated();
        detectIP();
        loadIPs();
        document.getElementById('ipLimitVal').textContent = ipLimit;
    }

    function updateLastUpdated() {
        const now = new Date();
        document.getElementById('lastUpdated').textContent =
            `Updated now · ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
    }

    // ── DETECT IP ──
    async function detectIP() {
        const disp = document.getElementById('ipInputDisplay');
        disp.textContent = 'Detecting…';
        try {
            const res = await fetch('https://api.ipify.org?format=json');
            const data = await res.json();
            detectedIP = data.ip;
            disp.textContent = detectedIP;
        } catch {
            disp.textContent = 'Could not detect IP';
            showToast('IP detection failed', 'error');
        }
    }

    // ── REGISTER IP ──
    async function handleRegisterIP() {
        const ip = document.getElementById('ipInputDisplay').textContent.trim();
        if (!isValidIP(ip)) { showToast('Invalid IP address', 'error'); return; }

        const btn = document.getElementById('registerBtn');
        btn.disabled = true;
        btn.innerHTML = '<div class="spinner" style="border-color:rgba(255,255,255,0.4);border-top-color:white;width:14px;height:14px;"></div> Registering…';

        try {
            const res = await fetch(`${API_BASE}/ips`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ key: currentKey, ip })
            });
            const data = await res.json();
            if (data.success) {
                showToast('IP registered successfully', 'success');
                loadIPs();
            } else {
                showToast(data.message || 'Failed to register', 'error');
            }
        } catch {
            showToast('Cannot connect to server', 'error');
        }

        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="plus" width="16" height="16"></i> Register IP';
        lucide.createIcons();
    }

    // ── LOAD IPs ──
    async function loadIPs() {
        try {
            const res = await fetch(`${API_BASE}/ips?key=${currentKey}`);
            const ips = await res.json();
            renderIPList(ips);
            updateLastUpdated();
        } catch {
            showToast('Cannot load IPs', 'error');
        }
    }

    // ── DELETE IP ──
    async function handleDeleteIP(id, ip) {
        if (!confirm(`Remove ${ip}?`)) return;
        try {
            await fetch(`${API_BASE}/ips/${id}?key=${currentKey}`, { method: 'DELETE' });
            showToast(`${ip} removed`, 'info');
            loadIPs();
        } catch {
            showToast('Failed to remove IP', 'error');
        }
    }

    function copyIP(ip) {
        navigator.clipboard.writeText(ip)
            .then(() => showToast('Copied', 'success'))
            .catch(() => showToast('Copy failed', 'error'));
    }

    // ── RENDER ──
    function renderIPList(ips) {
        const body = document.getElementById('ipListBody');
        const pill = document.getElementById('ipCountPill');
        const count = ips.length;
        pill.textContent = count;
        document.getElementById('activeIPCount').textContent = `${count} / ${ipLimit}`;
        document.getElementById('ipProgressBar').style.width = `${(count / ipLimit) * 100}%`;

        if (count === 0) {
            body.innerHTML = `<div class="empty-state"><div class="empty-icon"><i data-lucide="inbox" width="36" height="36"></i></div><p>No IPs registered yet</p></div>`;
            lucide.createIcons(); return;
        }

        body.innerHTML = ips.map(item => `
            <div class="ip-item">
                <div class="ip-item-icon"><i data-lucide="globe" width="18" height="18"></i></div>
                <div class="ip-item-info">
                    <div class="ip-item-addr">${item.ip}</div>
                    <div class="ip-item-date">${item.created_at}</div>
                </div>
                <div class="ip-item-right">
                    <span class="status-pill">Active</span>
                    <button class="ip-action-btn" onclick="copyIP('${item.ip}')"><i data-lucide="copy" width="15" height="15"></i></button>
                    <button class="ip-action-btn del" onclick="handleDeleteIP(${item.id}, '${item.ip}')"><i data-lucide="trash-2" width="15" height="15"></i></button>
                </div>
            </div>
        `).join('');
        lucide.createIcons();
    }

    // ── EXPIRY ──
    function startExpiryCountdown(expiresAt) {
        if (expiryTimer) clearInterval(expiryTimer);
        function update() {
            const diff = new Date(expiresAt) - new Date();
            if (diff <= 0) {
                document.getElementById('expiryDisplay').textContent = 'Expired';
                clearInterval(expiryTimer);
                showToast('Your key has expired', 'error');
                return;
            }
            const h = Math.floor(diff / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            document.getElementById('expiryDisplay').textContent = h > 0 ? `${h}h ${String(m).padStart(2,'0')}min` : `${m}min`;
        }
        update();
        expiryTimer = setInterval(update, 30000);
    }

    // ── HELPERS ──
    function isValidIP(ip) {
        return /^(([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\.){3}([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])$/.test(ip);
    }

    function showToast(msg, type = 'info') {
        const icons = { success:'check', error:'x', info:'info' };
        const t = document.createElement('div');
        t.className = `toast ${type}`;
        t.innerHTML = `<i data-lucide="${icons[type]}" width="14" height="14"></i> ${msg}`;
        document.getElementById('toastWrap').appendChild(t);
        lucide.createIcons();
        setTimeout(() => {
            t.style.transition = 'all 0.25s ease';
            t.style.opacity = '0';
            t.style.transform = 'translateY(-6px) scale(0.96)';
            setTimeout(() => t.remove(), 250);
        }, 2800);
    }

    // ── INIT ──
    document.addEventListener('keypress', e => {
        if (e.key === 'Enter' && document.getElementById('loginScreen').classList.contains('active')) handleLogin();
    });

    const savedKey = localStorage.getItem('proxyKey');
    if (savedKey) {
        document.getElementById('keyInput').value = savedKey;
        handleLogin();
    }

    window.addEventListener('load', () => lucide.createIcons());
</script>
</body>
</html>

